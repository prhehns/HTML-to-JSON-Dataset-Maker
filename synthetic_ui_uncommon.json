[
  {
    "label": "Toast",
    "contents": [
      {
        "type": "div",
        "attributes": {
          "role": "status",
          "aria-live": "polite",
          "class": "toast toast-success fixed bottom-6 right-6"
        },
        "children": [
          {
            "type": "span",
            "text": "Profile updated successfully"
          },
          {
            "type": "button",
            "attributes": {
              "aria-label": "Close",
              "class": "toast-close"
            }
          }
        ]
      }
    ]
  },
  {
    "label": "LoadingSpinner",
    "contents": [
      {
        "type": "div",
        "attributes": {
          "role": "status",
          "aria-busy": "true",
          "class": "spinner spinner-lg"
        },
        "children": [
          {
            "type": "span",
            "text": "Loading data..."
          }
        ]
      }
    ]
  },
  {
    "label": "Modal",
    "contents": [
      {
        "type": "div",
        "attributes": {
          "class": "modal-backdrop"
        },
        "children": [
          {
            "type": "section",
            "attributes": {
              "role": "dialog",
              "aria-modal": "true",
              "class": "modal"
            },
            "children": [
              {
                "type": "h2",
                "text": "Delete item?"
              },
              {
                "type": "p",
                "text": "This action cannot be undone."
              },
              {
                "type": "div",
                "children": [
                  {
                    "type": "button",
                    "text": "Cancel"
                  },
                  {
                    "type": "button",
                    "text": "Delete"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "label": "Hero",
    "contents": [
      {
        "type": "section",
        "attributes": {
          "class": "hero bg-cover text-center"
        },
        "children": [
          {
            "type": "h1",
            "text": "Build Better Interfaces"
          },
          {
            "type": "p",
            "text": "Design and deploy faster with our tools."
          },
          {
            "type": "button",
            "text": "Start Free Trial"
          }
        ]
      }
    ]
  },
  {
    "label": "ProgressBar",
    "contents": [
      {
        "type": "div",
        "attributes": {
          "role": "progressbar",
          "aria-valuemin": "0",
          "aria-valuemax": "100",
          "aria-valuenow": "68",
          "class": "progress"
        },
        "children": [
          {
            "type": "div",
            "attributes": {
              "class": "progress-fill",
              "style": "width:68%"
            }
          }
        ]
      }
    ]
  },
  {
    "label": "ChatBubble",
    "contents": [
      {
        "type": "div",
        "attributes": {
          "class": "chat-bubble right"
        },
        "children": [
          {
            "type": "span",
            "text": "Can we ship this today?"
          },
          {
            "type": "time",
            "text": "14:32"
          }
        ]
      }
    ]
  },
  {
    "label": "FileUpload",
    "contents": [
      {
        "type": "div",
        "attributes": {
          "class": "upload-dropzone"
        },
        "children": [
          {
            "type": "input",
            "attributes": {
              "type": "file",
              "accept": ".pdf,.docx",
              "class": "file-input"
            }
          },
          {
            "type": "p",
            "text": "Drag files here or click to browse"
          }
        ]
      }
    ]
  },
  {
    "label": "RangeSlider",
    "contents": [
      {
        "type": "label",
        "children": [
          {
            "type": "span",
            "text": "Volume"
          },
          {
            "type": "input",
            "attributes": {
              "type": "range",
              "min": "0",
              "max": "100",
              "value": "35",
              "class": "range-slider"
            }
          }
        ]
      }
    ]
  },
  {
    "label": "Badge",
    "contents": [
      {
        "type": "span",
        "attributes": {
          "class": "badge badge-success"
        },
        "text": "New"
      }
    ]
  },
  {
    "label": "Sitemap",
    "contents": [
      {
        "type": "nav",
        "attributes": {
          "aria-label": "Sitemap"
        },
        "children": [
          {
            "type": "ul",
            "children": [
              {
                "type": "li",
                "text": "Home"
              },
              {
                "type": "li",
                "text": "Products"
              },
              {
                "type": "li",
                "text": "Pricing"
              },
              {
                "type": "li",
                "text": "Contact"
              }
            ]
          }
        ]
      }
    ]
  }
]